{
  "ConnectionStrings": {
    "IdentityServerConnection": "Host=localhost;Port=5432;Database=sevsharks_interview_auth;UserId=postgres;Password=password",
    "InterviewTrainingConnection": "Host=localhost;Port=5432;Database=interview_training_interview;UserId=postgres;Password=password"
  },
  "MigrationSettings": {
    "IntervalMinutes": 1
  },
  "Elasticsearch": {
    "Uri": "http://localhost:9200",
    "IndexFormat": "interviewtraining-migrator-{0:yyyy.MM.dd}",
    "AutoRegisterTemplate": true,
    "AutoRegisterTemplateVersion": "ESv7",
    "NumberOfShards": 1,
    "NumberOfReplicas": 0
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  }
}
