{
  "ConnectionStrings": {
    "IdentityServerConnection": "Host=localhost;Port=5432;Database=sevsharks_interview_auth;UserId=postgres;Password=password",
    "InterviewTrainingConnection": "Host=localhost;Port=5432;Database=interview_training_interview;UserId=postgres;Password=password"
  },
  "MigrationSettings": {
    "IntervalMinutes": 1
  },
  "Serilog": {
    "Using": [ "Elastic.Serilog.Sinks" ],
    "MinimumLevel": { "Default": "Information" },
    "WriteTo": [
      {
        "Name": "Elasticsearch",
        "Args": {
          "bootstrapMethod": "Silent",
          "nodes": [ "http://localhost:9200" ],
          "dataStream": "interviewtraining-migrator-logs"
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  }
}
